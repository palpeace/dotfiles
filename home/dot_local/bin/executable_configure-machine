#!/usr/bin/env bash
set -euo pipefail

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles"
config_path="$config_dir/machine.env"

prompt_choice() {
    local prompt="$1"
    shift
    local options=("$@")
    local index=1
    local answer=""

    echo "$prompt" >&2
    for option in "${options[@]}"; do
        printf '  %d) %s\n' "$index" "$option" >&2
        index=$((index + 1))
    done

    while true; do
        read -r -p "Choose [1-${#options[@]}]: " answer || exit 1
        case "$answer" in
            ''|*[!0-9]*)
                ;;
            *)
                if [ "$answer" -ge 1 ] && [ "$answer" -le "${#options[@]}" ]; then
                    printf '%s\n' "$answer"
                    return 0
                fi
                ;;
        esac
    done
}

docker_mode="none"
docker_gpu="none"

mkdir -p "$config_dir"

echo "🧩 Configuring machine-specific options..."

docker_choice="$(prompt_choice \
    "Docker setup for this machine:" \
    "Do not install Docker" \
    "Install Docker Engine inside Ubuntu/WSL")"

case "$docker_choice" in
    1)
        docker_mode="none"
        docker_gpu="none"
        ;;
    2)
        docker_mode="engine"
        gpu_choice="$(prompt_choice \
            "GPU support for Docker on this machine:" \
            "CPU only" \
            "Enable NVIDIA GPU support")"

        case "$gpu_choice" in
            1)
                docker_gpu="none"
                ;;
            2)
                docker_gpu="nvidia"
                ;;
        esac
        ;;
esac

opencode_choice="$(prompt_choice \
    "OpenCode for this machine:" \
    "Do not install" \
    "Install OpenCode")"
opencode_mode="none"
[ "$opencode_choice" = "2" ] && opencode_mode="enabled"

paperclip_choice="$(prompt_choice \
    "Paperclip AI for this machine:" \
    "Do not install" \
    "Install Paperclip AI")"
paperclip_mode="none"
[ "$paperclip_choice" = "2" ] && paperclip_mode="enabled"

hermes_choice="$(prompt_choice \
    "Hermes Agent for this machine:" \
    "Do not install" \
    "Install Hermes Agent")"
hermes_mode="none"
[ "$hermes_choice" = "2" ] && hermes_mode="enabled"

tmp_config="$(mktemp)"
trap 'rm -f "$tmp_config"' EXIT

if [ -f "$config_path" ]; then
    grep -Ev '^(DOTFILES_DOCKER_MODE|DOTFILES_DOCKER_GPU|DOTFILES_HERMES|DOTFILES_PAPERCLIP|DOTFILES_OPENCODE)=' "$config_path" > "$tmp_config" || true
else
    printf '# Generated by configure-machine. Edit if this machine changes.\n' > "$tmp_config"
fi

cat >> "$tmp_config" <<EOF
DOTFILES_DOCKER_MODE=$docker_mode
DOTFILES_DOCKER_GPU=$docker_gpu
DOTFILES_HERMES=$hermes_mode
DOTFILES_PAPERCLIP=$paperclip_mode
DOTFILES_OPENCODE=$opencode_mode
EOF

mv "$tmp_config" "$config_path"
chmod 600 "$config_path"

echo "📝 Wrote $config_path"
echo "   DOTFILES_DOCKER_MODE=$docker_mode"
echo "   DOTFILES_DOCKER_GPU=$docker_gpu"
echo "   DOTFILES_HERMES=$hermes_mode"
echo "   DOTFILES_PAPERCLIP=$paperclip_mode"
echo "   DOTFILES_OPENCODE=$opencode_mode"
