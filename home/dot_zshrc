# --- 1. システム設定 ---
# コマンドラインでの # (コメント) を有効にする
setopt interactive_comments
# 履歴設定
setopt share_history
setopt hist_ignore_all_dups
setopt hist_reduce_blanks
setopt inc_append_history
setopt auto_cd
setopt auto_pushd
setopt pushd_ignore_dups
setopt pushd_minus
HISTSIZE=10000
SAVEHIST=10000
export PATH="$HOME/.local/bin:$PATH"
typeset -U path PATH
export LESS='-FRX'
export BAT_THEME='ansi'
export FZF_DEFAULT_OPTS='--height=40% --layout=reverse --border=rounded --info=inline --preview-window=right:50%:wrap'

# --- 2. ツール起動 ---
eval "$(~/.local/bin/mise activate zsh)"
eval "$(sheldon source)"
autoload -Uz compinit
zmodload zsh/complist
compinit -C
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
source <(fzf --zsh)
eval "$(atuin init zsh)"

# --- 3. 補完と候補表示 ---
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'
zstyle ':completion:*:warnings' format '%F{red}no matches found%f'
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$HOME/.cache/zsh/.zcompcache"
zstyle ':completion:*' completer _extensions _complete _approximate

# --- 4. キーバインドと操作性 ---
# ↑↓ と Ctrl+R は atuin が自動でバインドする
bindkey '^F' autosuggest-accept
bindkey '^J' fzf-cd-widget

fzf-cd-widget() {
  local dir

  dir="$(
    fd --type d --hidden --follow --exclude .git . "${1:-.}" 2>/dev/null |
      fzf --height 40% --reverse --prompt='cd > ' --preview 'eza --all --icons --group-directories-first --color=always {}'
  )" || return

  BUFFER="cd ${dir:q}"
  zle accept-line
}
zle -N fzf-cd-widget

# --- 5. 開発環境メンテナンス ---
project-root() {
  git rev-parse --show-toplevel 2>/dev/null || pwd
}

has-just-recipe() {
  command -v just >/dev/null 2>&1 || return 1
  [ -f Justfile ] || [ -f justfile ] || return 1
  just --summary 2>/dev/null | tr ' ' '\n' | rg -qx "$1"
}

has-package-script() {
  [ -f package.json ] || return 1
  jq -e --arg name "$1" '.scripts[$name] != null' package.json >/dev/null 2>&1
}

is-node-worktree() {
  [ -f package.json ] || [ -f pnpm-lock.yaml ] || [ -f turbo.json ]
}

is-rust-worktree() {
  [ -f Cargo.toml ] || [ -f Cargo.lock ]
}

is-markdown-worktree() {
  rg --files . 2>/dev/null | rg -q '\.(md|mdx)$'
}

sync-dotfiles() {
  local diff_status=0

  chezmoi diff || diff_status=$?
  if [ "$diff_status" -gt 1 ]; then
    echo "chezmoi diff failed; aborting apply." >&2
    return "$diff_status"
  fi

  chezmoi apply
}

update-all() {
  chezmoi update &&
    update-system
}

dev() {
  local root
  root="$(project-root)"
  cd "$root" || return 1

  if has-just-recipe dev; then
    just dev
    return
  fi

  if is-node-worktree; then
    if command -v pnpm >/dev/null 2>&1; then
      if [ -f package.json ] && has-package-script dev; then
        pnpm dev
      else
        echo "Node workspace detected."
        echo "Use 'pnpm install' if needed, then run the project-specific dev command."
      fi
    else
      echo "pnpm is not installed. Run setup-system first." >&2
      return 1
    fi
    return
  fi

  if is-rust-worktree; then
    if command -v bacon >/dev/null 2>&1; then
      bacon
    else
      cargo run
    fi
    return
  fi

  if is-markdown-worktree; then
    echo "Markdown workspace detected."
    echo "Use 'check' to run prettier / markdownlint checks."
    return
  fi

  echo "No supported project type detected in $root." >&2
  echo "Expected Justfile/justfile, package.json, Cargo.toml, or Markdown files." >&2
  return 1
}

check() {
  local root
  root="$(project-root)"
  cd "$root" || return 1

  if has-just-recipe check; then
    just check
    return
  fi

  if is-rust-worktree; then
    cargo fmt --check &&
      cargo clippy --all-targets --all-features -- -D warnings &&
      { command -v cargo-nextest >/dev/null 2>&1 && cargo nextest run || cargo test; }
    return
  fi

  if is-node-worktree; then
    if ! command -v pnpm >/dev/null 2>&1; then
      echo "pnpm is not installed. Run setup-system first." >&2
      return 1
    fi

    local ran=0

    if has-package-script lint; then
      pnpm lint || return 1
      ran=1
    fi

    if has-package-script typecheck; then
      pnpm typecheck || return 1
      ran=1
    fi

    if has-package-script test; then
      pnpm test || return 1
      ran=1
    fi

    if command -v prettier >/dev/null 2>&1 && rg --files . 2>/dev/null | rg -q '\.(md|mdx|json|ya?ml|ts|tsx|js|jsx)$'; then
      prettier --check . || return 1
      ran=1
    fi

    if [ "$ran" -eq 0 ]; then
      echo "No supported package.json checks found." >&2
      return 1
    fi

    return
  fi

  if is-markdown-worktree; then
    local ran=0

    if command -v prettier >/dev/null 2>&1; then
      prettier --check . || return 1
      ran=1
    fi

    if command -v markdownlint-cli2 >/dev/null 2>&1; then
      markdownlint-cli2 "**/*.md" "**/*.mdx" || return 1
      ran=1
    fi

    if [ "$ran" -eq 0 ]; then
      echo "No Markdown check tools found. Run setup-system first." >&2
      return 1
    fi

    return
  fi

  echo "No supported project type detected in $root." >&2
  echo "Expected Justfile/justfile, package.json, Cargo.toml, or Markdown files." >&2
  return 1
}

# --- 6. エイリアス ---
alias ls="eza --icons --git"
alias ll="eza -ahl --icons --git"
alias la="eza -a --icons --git"
alias tree="eza --tree --icons --git-ignore"
alias cat="bat --paging=never"
alias cd="z"
alias lg="lazygit"
alias ld="lazydocker"
alias ah="z ~/.local/share/agents-home"
alias r2="z ~/self/r2"
alias ze="zed ."

