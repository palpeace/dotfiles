[core]
    editor = vim

[url "git@github-self:"]
    insteadOf = https://github.com/
    insteadOf = https://www.github.com/
    insteadOf = git@github.com:
    insteadOf = ssh://git@github.com/

[include]
    path = ~/.gitconfig.local

[includeIf "gitdir:~/work/"]
    path = ~/.gitconfig-work.local
