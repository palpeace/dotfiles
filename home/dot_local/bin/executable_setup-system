#!/usr/bin/env bash
set -euo pipefail

PATH="$HOME/.local/bin:${PATH:-/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin}"
export PATH

base_apt_packages=(
    git
    curl
    zsh
    build-essential
    pkg-config
    libssl-dev
    unzip
    xz-utils
    bubblewrap
    fonts-noto-color-emoji
)

# Browser runtimes such as Chromium / Playwright need these shared libraries.
browser_runtime_apt_packages=(
    libnss3
    libnspr4
)

require_github_cli_auth() {
    local gh_bin=""

    gh_bin="$(command -v gh 2>/dev/null || true)"

    if [ -z "$gh_bin" ]; then
        gh_bin="$("$HOME/.local/bin/mise" which gh 2>/dev/null || true)"
    fi

    if [ -z "$gh_bin" ] || [ ! -x "$gh_bin" ]; then
        echo "📦 Installing GitHub CLI with mise..."
        "$HOME/.local/bin/mise" use --global github-cli@latest
        gh_bin="$("$HOME/.local/bin/mise" which gh 2>/dev/null || true)"
    fi

    if [ -z "$gh_bin" ] || [ ! -x "$gh_bin" ]; then
        echo "❌ GitHub CLI binary could not be resolved." >&2
        exit 1
    fi

    if ! "$gh_bin" auth status >/dev/null 2>&1; then
        if [ -t 0 ] && [ -t 1 ]; then
            echo "🔐 GitHub CLI authentication is required before setup-system." >&2
            echo "🔐 Starting: gh auth login --web" >&2
            "$gh_bin" auth login --web
        else
            echo "❌ GitHub CLI authentication is required before setup-system." >&2
            echo "❌ Run 'gh auth login --web' in an interactive shell, then rerun setup-system." >&2
            exit 1
        fi
    fi

    if ! "$gh_bin" auth status >/dev/null 2>&1; then
        echo "❌ GitHub CLI authentication did not complete successfully." >&2
        echo "❌ Run 'gh auth login --web' in an interactive shell, then rerun setup-system." >&2
        exit 1
    fi

    export GITHUB_TOKEN
    GITHUB_TOKEN="$("$gh_bin" auth token 2>/dev/null || echo "")"

    if [ -z "$GITHUB_TOKEN" ]; then
        echo "❌ GitHub CLI is authenticated, but no token was returned." >&2
        echo "❌ Re-run 'gh auth login --web' in an interactive shell, then rerun setup-system." >&2
        exit 1
    fi
}

resolve_apt_package() {
    local package="$1"
    local policy_output=""

    policy_output="$(apt-cache policy "$package" 2>/dev/null || true)"

    if [[ "$policy_output" == *"Candidate: (none)"* ]]; then
        return 1
    fi

    if [[ "$policy_output" == *"Candidate:"* ]]; then
        printf '%s\n' "$package"
        return 0
    fi

    return 1
}

alsa_runtime_package="$(resolve_apt_package libasound2t64 || resolve_apt_package libasound2 || true)"

if [ -n "$alsa_runtime_package" ]; then
    browser_runtime_apt_packages+=("$alsa_runtime_package")
else
    echo "⚠️  Could not resolve an ALSA runtime package (tried libasound2t64, libasound2)." >&2
fi

# Switch to JAIST mirror for faster downloads in Japan.
sources_file="/etc/apt/sources.list.d/ubuntu.sources"
jp_mirror="http://ftp.jaist.ac.jp/pub/Linux/ubuntu/"
if [ -f "$sources_file" ] && ! grep -q "$jp_mirror" "$sources_file"; then
    echo "🌏 Switching apt mirror to ftp.jaist.ac.jp..."
    sudo sed -i "s|http://[a-z.]*archive.ubuntu.com/ubuntu/|${jp_mirror}|g" "$sources_file"
fi

echo "🚀 Installing base system dependencies..."
sudo apt update
sudo apt install -y "${base_apt_packages[@]}" "${browser_runtime_apt_packages[@]}"

echo "🔤 Rebuilding font cache..."
fc-cache -fv

echo "🔎 Checking for Noto Color Emoji..."
if ! fc-list | grep -i "Noto Color Emoji"; then
    echo "⚠️  Noto Color Emoji was not found in fc-list output." >&2
fi

if [ "${SHELL:-}" != "$(command -v zsh)" ]; then
    echo "🔧 Switching login shell to zsh..."
    sudo chsh -s "$(command -v zsh)" "$(whoami)"
fi

if ! command -v mise >/dev/null 2>&1; then
    echo "📦 Installing mise..."
    curl https://mise.run | sh
fi

require_github_cli_auth

gh auth setup-git >/dev/null 2>&1 || echo "⚠️  Could not configure GitHub CLI as git credential helper." >&2

echo "📦 Installing managed tools with mise..."
export MISE_FETCH_REMOTE_VERSIONS_TIMEOUT="${MISE_FETCH_REMOTE_VERSIONS_TIMEOUT:-60}"
setup_failures=()

# mise does not resolve implicit backend dependencies (npm:→node, cargo:→rust).
# Runtimes are fatal — without them, npm:/cargo:/go: tools cannot install.
# MISE_QUIET suppresses warnings about unresolvable npm:/cargo: tools that
# depend on runtimes not yet installed at this point.
echo "📦 Installing runtimes (rust, node, go, python) first..."
MISE_QUIET=1 "$HOME/.local/bin/mise" install -y --jobs=1 rust node go python

eval "$("$HOME/.local/bin/mise" activate bash)"

# Remaining tools: report failures but continue so one broken tool doesn't
# block the entire environment.
# If signature verification fails (e.g. Rekor key format mismatch in mise),
# retry once with verification disabled.
echo "📦 Installing remaining tools..."
if ! "$HOME/.local/bin/mise" install -y; then
    echo "⚠️  Retrying with signature verification disabled..." >&2
    if ! MISE_COSIGN_VERIFY=0 "$HOME/.local/bin/mise" install -y; then
        setup_failures+=("mise install (some tools failed — rerun 'mise install' to retry)")
    fi
fi

unset GITHUB_TOKEN

if ! command -v claude >/dev/null 2>&1; then
    echo "🤖 Installing Claude Code..."
    if ! curl -fsSL https://claude.ai/install.sh | bash; then
        setup_failures+=("Claude Code")
    fi
fi

if ! command -v kiro-cli >/dev/null 2>&1; then
    echo "🤖 Installing Kiro CLI..."
    if ! curl -fsSL https://cli.kiro.dev/install | bash; then
        setup_failures+=("Kiro CLI")
    fi
fi

if [ ${#setup_failures[@]} -gt 0 ]; then
    echo "" >&2
    echo "⚠️  setup-system completed with errors:" >&2
    for f in "${setup_failures[@]}"; do
        echo "   - $f" >&2
    done
    echo "   Run 'setup-system' again to retry failed items." >&2
    exit 1
fi
