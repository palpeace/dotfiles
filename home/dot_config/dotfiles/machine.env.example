# Copy to ~/.config/dotfiles/machine.env and edit per machine.

# Docker installation mode:
#   none   - do not install Docker
#   engine - install Docker Engine directly inside Ubuntu/WSL
DOTFILES_DOCKER_MODE=none

# GPU support for Docker:
#   none   - standard CPU-only containers
#   nvidia - install NVIDIA Container Toolkit for WSL2
DOTFILES_DOCKER_GPU=none
